{
  "permissions": {
    "allow": [
      "Bash(mvn -q -DskipTests compile)",
      "Bash(ls mvnw*)",
      "Bash(where mvn.cmd)",
      "Bash(which javac *)",
      "Bash(cmd.exe //c \"where mvn 2>nul & where mvn.cmd 2>nul & where javac 2>nul\")",
      "Bash(./mvnw.cmd -q -DskipTests compile)",
      "Bash(cmd.exe //c \"mvnw.cmd -q -DskipTests compile\")",
      "Bash(cmd.exe //c \".\\\\\\\\mvnw.cmd -q -DskipTests compile\")",
      "Bash(cmd.exe //c \".\\\\\\\\mvnw.cmd -DskipTests compile 2>&1\")",
      "Bash(cmd.exe *)"
    ]
  }
}
